# Database
DATABASE_URL=postgresql+asyncpg://neon:neon_password@localhost:5432/neon_stack
DATABASE_URL_SYNC=postgresql+psycopg2://neon:neon_password@localhost:5432/neon_stack

# JWT
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS — фронтенд
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000","http://127.0.0.1:5500"]

# S3 / MinIO (Этап 2 — заполнится позже)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_BOOKS=neon-books
S3_REGION=us-east-1

# AI (Этап 3 — заполнится позже)
ANTHROPIC_API_KEY=

# App
APP_NAME=NEON STACK
DEBUG=True
